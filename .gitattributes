# Normalize all text files to LF
* text=auto eol=lf

# Ensure shell scripts use LF
*.sh text eol=lf

# Ensure Go files use LF
*.go text eol=lf

# Ensure JSON/YAML use LF
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
